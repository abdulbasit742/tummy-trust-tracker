# --- Supabase ---
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_PUBLISHABLE_KEY"

# --- AI Food Checker (local, self-hosted) ---
# Defaults target a local Ollama server. Inference is free, private, offline.
VITE_AI_ENDPOINT="http://127.0.0.1:11434/api/chat"
VITE_AI_MODEL="qwen2.5:32b"
# Set to "true" to skip the model and use the built-in static fallback only.
VITE_AI_DRY_RUN="false"
